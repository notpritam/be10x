# --- be10x deploy config — copy to .env and fill in ---

# Public domain for the board. A DNS A record must point at this server; Caddy gets HTTPS automatically.
DOMAIN=board.example.com

# Where the SQLite DB lives inside the container (persisted on the be10x-data volume). Leave as-is.
GFA_DB_PATH=/data/be10x.db

# Send the session cookie only over HTTPS. Keep =1 for any hosted deploy (you're behind Caddy's TLS).
GFA_SECURE_COOKIES=1

# The Claude CLI the runner spawns for agent tasks (pre-installed in the image). Leave as-is.
GFA_CLAUDE_BIN=claude

# --- Agent auth — OPTIONAL. The board (tasks, plans, review, share) works without it; only the AGENT
#     needs credentials. Pick ONE mode: ---
# Mode A — an API key. The runner passes the container env to each agent, so this is all it takes.
ANTHROPIC_API_KEY=
# Mode B — mount your logged-in Claude credentials instead (uncomment the ~/.claude volume in
#          docker-compose.yml) and leave ANTHROPIC_API_KEY blank.

# Optional defaults for agent runs.
# GFA_MODEL=
# GFA_EFFORT=

# --- QA bug capture storage (browser extension artifacts: screenshot / DOM / network / rrweb) ---
# Where capture bytes are stored. 'local' (default) writes them to GFA_BLOB_DIR on this host and serves them
# back over signed /api/blob/:key URLs. 's3' is a stub seam (src/bugs/storage.js) for object storage later.
BUG_STORAGE=local
GFA_BLOB_DIR=/data/blobs
# Base URL the board mints into signed artifact links handed to agents/multimodal steps. Defaults to
# http://127.0.0.1:<port>; set to your PUBLIC board URL so links are reachable off-host (e.g. remote agents).
# GFA_BLOB_BASE_URL=https://be10x.notpritam.in
# Signing secret for blob URLs. Optional — if unset, a per-store secret is generated + persisted in GFA_BLOB_DIR.
# GFA_BLOB_SECRET=

# --- LEGACY: UploadThing. No longer used (storage is local-disk above). Kept only for old connector configs. ---
# UPLOADTHING_TOKEN=
