# be10x environment file (rendered per-env by scripts/vm-setup.sh). Read by the systemd unit.
# Durable state lives OUTSIDE the source tree so `git pull` / redeploys never touch it.
GFA_DB_PATH=__DATA__/be10x.db
# Local-disk blob store for QA bug-capture artifacts (replaces UploadThing). See src/bugs/storage.js.
GFA_BLOB_DIR=__DATA__/blobs
BUG_STORAGE=local
# Prod is HTTPS end-to-end behind Caddy → Secure cookies. Dev is plain loopback → leave unset (=0).
GFA_SECURE_COOKIES=__SECURE__
# Give the runner-spawned `claude` a real PATH (systemd has none) so it can find node + the CLI.
PATH=__NODEDIR__:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
GFA_CLAUDE_BIN=claude
HOME=__HOME__
# Machine identity — labels this VM's runner in run records so its work is attributable.
GFA_WORKER_ID=__WORKER__
